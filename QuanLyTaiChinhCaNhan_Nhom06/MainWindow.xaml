<Window x:Class="QuanLyTaiChinhCaNhan_Nhom06.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản Lý Tài Chính Cá Nhân" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon Kind="PiggyBank" 
                                   Width="80" Height="80" 
                                   Foreground="#2563EB"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
            
            <TextBlock Text="Chào mừng đến với Quản Lý Tài Chính Cá Nhân" 
                      FontSize="24" FontWeight="Bold"
                      Foreground="#1E293B"
                      HorizontalAlignment="Center"
                      TextAlignment="Center"
                      Margin="0,0,0,20"/>
            
            <TextBlock Text="Ứng dụng này đang trong quá trình phát triển..." 
                      FontSize="14" 
                      Foreground="#64748B"
                      HorizontalAlignment="Center"
                      TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
