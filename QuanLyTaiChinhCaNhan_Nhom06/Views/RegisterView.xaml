
<Window x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký - Quản lý tài chính cá nhân"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="25" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="15" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- Background Gradient -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#764BA2" Offset="0.5"/>
                    <GradientStop Color="#F093FB" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE - DECORATIVE -->
            <Grid Grid.Column="0">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="White">

                    <!-- Icon/Image -->
                    <Image Source="/Assets/register.png"
                           Width="280"
                           Height="280"
                           Margin="0,0,0,30"
                           Opacity="0.95"/>

                    <!-- Title -->
                    <TextBlock Text="Bắt đầu hành trình"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Tạo tài khoản để quản lý tài chính hiệu quả"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Opacity="0.9"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Grid>

            <!-- RIGHT SIDE - REGISTER FORM -->
            <Grid Grid.Column="1">
                <Border Padding="50"
                        Background="#FFFFFF"
                        CornerRadius="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel VerticalAlignment="Top">

                            <!-- Header -->
                            <TextBlock Text="Tạo tài khoản mới"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#1a1a2e"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Đăng ký để bắt đầu quản lý tài chính"
                                       FontSize="14"
                                       Foreground="#666"
                                       Margin="0,0,0,30"/>

                            <!-- Full Name Input -->
                            <TextBlock Text="Họ và tên"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1a1a2e"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F0F2F5"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,18"
                                    BorderThickness="2"
                                    BorderBrush="Transparent">
                                <TextBox Text="{Binding FullName}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Foreground="#1a1a2e"
                                         Padding="0"/>
                            </Border>

                            <!-- Username Input -->
                            <TextBlock Text="Tên đăng nhập"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1a1a2e"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F0F2F5"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,18"
                                    BorderThickness="2"
                                    BorderBrush="Transparent">
                                <TextBox Text="{Binding Username}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Foreground="#1a1a2e"
                                         Padding="0"/>
                            </Border>

                            <!-- Email Input -->
                            <TextBlock Text="Email"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1a1a2e"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F0F2F5"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,18"
                                    BorderThickness="2"
                                    BorderBrush="Transparent">
                                <TextBox Text="{Binding Email}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Foreground="#1a1a2e"
                                         Padding="0"/>
                            </Border>

                            <!-- Password Input -->
                            <TextBlock Text="Mật khẩu"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1a1a2e"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F0F2F5"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,28"
                                    BorderThickness="2"
                                    BorderBrush="Transparent">
                                <PasswordBox x:Name="PasswordBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="14"
                                             Padding="0"/>
                            </Border>

                            <!-- Terms & Conditions -->
                            <CheckBox Margin="0,0,0,24"
                                      Foreground="#666"
                                      FontSize="12">
                                <TextBlock>
                                    <Run Text="Tôi đồng ý với "/>
                                    <Run Text="Điều khoản dịch vụ" Foreground="#667EEA" FontWeight="Bold"/>
                                    <Run Text=" và "/>
                                    <Run Text="Chính sách bảo mật" Foreground="#667EEA" FontWeight="Bold"/>
                                </TextBlock>
                            </CheckBox>

                            <!-- Register Button -->
                            <Button Content="ĐĂNG KÝ"
                                    Height="48"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Background="#667EEA"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Margin="0,0,0,20"
                                    Cursor="Hand"
                                    Command="{Binding RegisterCommand}"
                                    Style="{StaticResource ButtonStyle}"/>

                            <!-- Login Link -->
                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Đã có tài khoản? "
                                           VerticalAlignment="Center"
                                           Foreground="#666"
                                           FontSize="13"/>

                                <Button Grid.Column="1"
                                        Content="Đăng nhập"
                                        Padding="0"
                                        Margin="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#667EEA"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        VerticalAlignment="Center"
                                        Command="{Binding OpenLoginCommand}"
                                        Cursor="Hand"/>

                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>