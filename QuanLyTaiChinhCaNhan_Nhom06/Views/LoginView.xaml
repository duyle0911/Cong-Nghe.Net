
<Window x:Class="QuanLyTaiChinhCaNhan_Nhom06.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - Quản lý tài chính cá nhân"
        Height="680"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="25" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="15" Opacity="0.3" Color="Black"/>
        </Border.Effect>

        <Grid>
          
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#667EEA" Offset="0"/>
                    <GradientStop Color="#764BA2" Offset="0.5"/>
                    <GradientStop Color="#F093FB" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE - DECORATIVE -->
            <Grid Grid.Column="0">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextBlock.Foreground="White">

                    <!-- Icon/Image -->
                    <Image Source="/Assets/login.png"
                           Width="280"
                           Height="280"
                           Margin="0,0,0,30"
                           Opacity="0.95"/>

                    <!-- Title -->
                    <TextBlock Text="Quản lý tài chính cá nhân"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Subtitle -->
                    <TextBlock Text="Kiểm soát chi tiêu, đạt mục tiêu tài chính"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Opacity="0.9"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Grid>

            <!-- RIGHT SIDE - LOGIN FORM -->
            <Grid Grid.Column="1">
                <Border Padding="50"
                        Background="#FFFFFF"
                        CornerRadius="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <StackPanel VerticalAlignment="Center">

                        <!-- Header -->
                        <TextBlock Text="Chào mừng trở lại"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1a1a2e"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Đăng nhập vào tài khoản của bạn"
                                   FontSize="14"
                                   Foreground="#666"
                                   Margin="0,0,0,40"/>

                        <!-- Username Input -->
                        <TextBlock Text="Tên đăng nhập hoặc Email"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1a1a2e"
                                   Margin="0,0,0,8"/>

                        <Border Background="#F0F2F5"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,20"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <TextBox Text="{Binding Username}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"
                                     Foreground="#1a1a2e"
                                     Padding="0"/>
                        </Border>

                        <!-- Password Input -->
                        <TextBlock Text="Mật khẩu"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1a1a2e"
                                   Margin="0,0,0,8"/>

                        <Border Background="#F0F2F5"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,8"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <PasswordBox x:Name="PasswordBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Padding="0"/>
                        </Border>

                        <!-- Remember & Forgot -->
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Content="Ghi nhớ tôi"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Foreground="#666"
                                      FontSize="12"/>

                            <TextBlock Grid.Column="1"
                                       Text="Quên mật khẩu?"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="#667EEA"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Cursor="Hand"/>
                        </Grid>

                        <!-- Login Button -->
                        <Button Content="ĐĂNG NHẬP"
                                Click="Login_Click"
                                Height="48"
                                FontWeight="Bold"
                                FontSize="14"
                                Background="#667EEA"
                                Foreground="White"
                                BorderThickness="0"
                                Margin="0,0,0,20"
                                Cursor="Hand"
                                Style="{StaticResource ButtonStyle}"/>

                        <!-- Sign Up Link -->
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Chưa có tài khoản? "
                                       VerticalAlignment="Center"
                                       Foreground="#666"
                                       FontSize="13"/>

                            <Button Grid.Column="1"
                                    Content="Đăng ký ngay"
                                    Padding="0"
                                    Margin="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#667EEA"
                                    FontWeight="Bold"
                                    FontSize="13"
                                    VerticalAlignment="Center"
                                    Command="{Binding OpenRegisterCommand}"
                                    Cursor="Hand"/>

                        </Grid>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
